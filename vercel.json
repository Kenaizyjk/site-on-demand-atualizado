{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "redirects": [
    { "source": "/precos", "destination": "/#contato", "permanent": true },
    { "source": "/casos", "destination": "/", "permanent": false },
    { "source": "/casos/:path*", "destination": "/", "permanent": false },
    { "source": "/casos-v2", "destination": "/", "permanent": true },
    { "source": "/privacidade", "destination": "/", "permanent": false },
    { "source": "/termos", "destination": "/", "permanent": false },
    { "source": "/politica-de-privacidade", "destination": "/", "permanent": true },
    { "source": "/termos-de-uso", "destination": "/", "permanent": true },
    { "source": "/diagnostico", "destination": "/#contato", "permanent": false },
    { "source": "/clinicas", "destination": "/#contato", "permanent": false },
    { "source": "/calculadora-roi", "destination": "/#contato", "permanent": true },
    { "source": "/recursos", "destination": "/#contato", "permanent": true },
    { "source": "/portfolio", "destination": "/", "permanent": true },
    { "source": "/sobre", "destination": "/", "permanent": true },
    { "source": "/old-services", "destination": "/#servicos", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
